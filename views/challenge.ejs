<%- include('header') %>
<a href="/" class="back-link">← Back</a>
<div class="card">
  <div class="challenge-header"><span class="badge badge-<%= challenge.category %>"><%= challenge.category.toUpperCase() %></span><h1><%= challenge.title %></h1></div>
  <% if (challenge.description) { %><p class="challenge-desc"><%- linkify(challenge.description) %></p><% } %>
  <div class="challenge-meta"><span><%= challenge.challenge_date %></span><span><% if (challenge.scoring_type === 'min_time') { %>Time (lower = better)<% } else { %>Reps (higher = better)<% } %></span><span>Unit: <strong><%= challenge.unit %></strong></span><span>Team: <strong><%= challenge.team_name ? challenge.team_name : 'All Teams' %></strong></span></div>
</div>
<div class="card score-card">
  <% const isTime = challenge.scoring_type === 'min_time'; %>
  <% if (!isOpen) { %>
    <h3>🔒 Opens <%= challenge.challenge_date %></h3>
    <p class="muted">This challenge isn't open yet — you'll be able to submit your score on <strong><%= challenge.challenge_date %></strong>.</p>
  <% } else if (myScore) { %>
    <h3>Your Submission</h3><p>You scored <strong><%= formatScore(myScore.score_value, challenge.scoring_type, challenge.unit) %></strong></p>
    <details class="update-section"><summary>Update</summary>
      <form method="POST" action="/challenge/<%= challenge.id %>/submit" class="inline-form">
        <% if (isTime) { const t = Number(myScore.score_value); const mm = Math.floor(t/60); const ss = Math.round((t - mm*60)*100)/100; %>
          <span class="time-inputs"><input type="number" name="minutes" min="0" step="1" value="<%= mm %>" aria-label="minutes" required> <span class="time-colon">min</span> <input type="number" name="seconds" min="0" max="59.99" step="0.01" value="<%= ss %>" aria-label="seconds" required> <span class="time-colon">sec</span></span>
        <% } else { %>
          <input type="number" name="scoreValue" step="0.01" min="0" value="<%= myScore.score_value %>" required>
        <% } %>
        <button type="submit" class="btn btn-primary">Update</button>
      </form>
    </details>
  <% } else { %>
    <h3>Submit Score</h3>
    <form method="POST" action="/challenge/<%= challenge.id %>/submit" class="inline-form">
      <% if (isTime) { %>
        <span class="time-inputs"><input type="number" name="minutes" min="0" step="1" placeholder="0" aria-label="minutes" required autofocus> <span class="time-colon">min</span> <input type="number" name="seconds" min="0" max="59.99" step="0.01" placeholder="0" aria-label="seconds" required> <span class="time-colon">sec</span></span>
      <% } else { %>
        <input type="number" name="scoreValue" step="0.01" min="0" placeholder="Enter score" required autofocus><span class="unit-label"><%= challenge.unit %></span>
      <% } %>
      <button type="submit" class="btn btn-primary">Submit</button>
    </form>
  <% } %>
</div>
<h2>Results</h2>
<% if (rankedScores.length === 0) { %><div class="card"><p class="muted">No scores yet. Be first! 🏆</p></div><% } else { %>
  <table class="leaderboard-table"><thead><tr><th>Rank</th><th>Player</th><th>Score</th><th>Points</th></tr></thead><tbody>
    <% rankedScores.forEach(s => { %>
      <tr class="<%= s.rank <= 3 ? 'rank-' + s.rank : '' %> <%= s.user_id === user.id ? 'is-you' : '' %>"><td class="rank-cell"><% if (s.rank === 1) { %>🥇<% } else if (s.rank === 2) { %>🥈<% } else if (s.rank === 3) { %>🥉<% } else { %>#<%= s.rank %><% } %><% if (s.tied) { %> <span class="tie-tag">TIE</span><% } %></td><td><%= s.username %></td><td><strong><%= formatScore(s.score_value, challenge.scoring_type, challenge.unit) %></strong></td><td><span class="points-badge"><%= s.points %> pts</span></td></tr>
    <% }) %>
  </tbody></table>
<% } %>
<%- include('footer') %>