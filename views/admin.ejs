<%- include('header', { active: 'admin' }) %>
<h1>⚙️ Admin Panel</h1>

<!-- ===== Create Challenge ===== -->
<div class="card">
  <h2>Create Challenge</h2>
  <form method="POST" action="/admin/create-challenge">
    <div class="form-group"><label>Title *</label><input type="text" name="title" required></div>
    <div class="form-row">
      <div class="form-group"><label>Category *</label><select name="category" required><option value="">Select...</option><option value="plyometrics">Plyometrics</option><option value="sprinting">Sprinting</option><option value="calisthenics">Calisthenics</option><option value="hockey">Hockey</option></select></div>
      <div class="form-group"><label>Scoring *</label><select name="scoringType" required><option value="">Select...</option><option value="max_reps">Max Reps</option><option value="min_time">Fastest Time</option></select></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Unit *</label><input type="text" name="unit" required></div>
      <div class="form-group"><label>Date *</label><input type="date" name="challengeDate" required value="<%= new Date().toISOString().split('T')[0] %>"></div>
    </div>
    <div class="form-group"><label>Team</label><select name="team_id"><option value="">👥 All Teams (global)</option><% teams.forEach(t => { %><option value="<%= t.id %>"><%= t.name %></option><% }) %></select></div>
    <div class="form-group"><label>Description</label><textarea name="description" rows="2"></textarea></div>
    <button type="submit" class="btn btn-primary btn-lg">Post Challenge</button>
  </form>
</div>

<!-- ===== Teams ===== -->
<h2>Teams</h2>
<div class="card">
  <form method="POST" action="/admin/create-team" class="inline-form">
    <input type="text" name="name" placeholder="New team name" required>
    <button type="submit" class="btn btn-primary">Add Team</button>
  </form>
  <% if (teams.length === 0) { %>
    <p class="muted" style="margin-top:12px;">No teams yet. Add one above, then assign players and challenges to it.</p>
  <% } else { %>
    <table class="leaderboard-table" style="margin-top:16px;">
      <thead><tr><th>Team</th><th>Players</th><th>Challenges</th><th></th></tr></thead>
      <tbody>
        <% teams.forEach(t => { %>
          <tr>
            <td><form method="POST" action="/admin/rename-team/<%= t.id %>" class="inline-form"><input type="text" name="name" value="<%= t.name %>" required><button type="submit" class="btn btn-sm btn-secondary">Rename</button></form></td>
            <td><%= t.member_count %></td>
            <td><%= t.challenge_count %></td>
            <td><form method="POST" action="/admin/delete-team/<%= t.id %>" style="display:inline;" onsubmit="return confirm('Delete team <%= t.name %>? Its players become unassigned and its challenges become global.')"><button type="submit" class="btn btn-sm btn-danger">Delete</button></form></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- ===== Add User ===== -->
<h2>Add User</h2>
<div class="card">
  <form method="POST" action="/admin/create-user">
    <div class="form-row">
      <div class="form-group"><label>Username *</label><input type="text" name="username" minlength="3" required></div>
      <div class="form-group"><label>Password *</label><input type="text" name="password" minlength="4" required></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Team</label><select name="team_id"><option value="">— No team —</option><% teams.forEach(t => { %><option value="<%= t.id %>"><%= t.name %></option><% }) %></select></div>
      <div class="form-group"><label>Role</label><label class="checkbox-label"><input type="checkbox" name="is_admin" value="1"> Admin</label></div>
    </div>
    <button type="submit" class="btn btn-primary btn-lg">Create User</button>
  </form>
</div>

<!-- ===== Manage Users ===== -->
<h2>Team Members</h2>
<div class="user-admin-list">
  <% users.forEach(u => { %>
    <div class="card user-admin-card">
      <div class="user-admin-head">
        <strong><%= u.username %></strong>
        <%= u.is_admin ? '👑 Admin' : 'Player' %><% if (u.team_name) { %> · <span class="team-tag"><%= u.team_name %></span><% } %>
        <% if (u.id === currentUserId) { %> <span class="muted">(you)</span><% } %>
      </div>

      <form method="POST" action="/admin/edit-user/<%= u.id %>" class="user-admin-row">
        <input type="text" name="username" value="<%= u.username %>" minlength="3" required>
        <select name="team_id">
          <option value="">— No team —</option>
          <% teams.forEach(t => { %><option value="<%= t.id %>" <%= u.team_id === t.id ? 'selected' : '' %>><%= t.name %></option><% }) %>
        </select>
        <label class="checkbox-label"><input type="checkbox" name="is_admin" value="1" <%= u.is_admin ? 'checked' : '' %> <%= u.id === currentUserId ? 'disabled' : '' %>> Admin</label>
        <button type="submit" class="btn btn-sm btn-primary">Save</button>
      </form>

      <div class="user-admin-actions">
        <form method="POST" action="/admin/reset-password/<%= u.id %>" class="inline-form" onsubmit="return confirm('Reset this user\'s password?')">
          <input type="password" name="newPassword" placeholder="New password" minlength="4" required>
          <button type="submit" class="btn btn-sm btn-secondary">Set Password</button>
        </form>
        <% if (u.id !== currentUserId) { %>
          <form method="POST" action="/admin/delete-user/<%= u.id %>" style="display:inline;" onsubmit="return confirm('Delete <%= u.username %> and all their scores? This cannot be undone.')">
            <button type="submit" class="btn btn-sm btn-danger">Delete User</button>
          </form>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<!-- ===== Existing Challenges ===== -->
<h2>Existing Challenges</h2>
<div class="challenge-list">
  <% challenges.forEach(c => { %>
    <div class="challenge-admin-item">
      <div class="challenge-item">
        <span class="badge badge-<%= c.category %>"><%= c.category.toUpperCase() %></span>
        <div class="challenge-item-info">
          <strong><%= c.title %></strong>
          <span class="muted"><%= c.challenge_date %></span>
        </div>
        <form method="POST" action="/admin/edit-challenge/<%= c.id %>" class="inline-form" title="Reassign team">
          <select name="team_id" onchange="this.form.submit()">
            <option value="" <%= c.team_id ? '' : 'selected' %>>👥 All Teams</option>
            <% teams.forEach(t => { %><option value="<%= t.id %>" <%= c.team_id === t.id ? 'selected' : '' %>><%= t.name %></option><% }) %>
          </select>
        </form>
        <a href="/challenge/<%= c.id %>" class="btn btn-sm btn-secondary">View</a>
        <form method="POST" action="/admin/delete-challenge/<%= c.id %>" style="display:inline;" onsubmit="return confirm('Delete?')"><button type="submit" class="btn btn-sm btn-danger">Delete</button></form>
      </div>
      <details class="challenge-edit">
        <summary>✏️ Edit challenge</summary>
        <form method="POST" action="/admin/update-challenge/<%= c.id %>">
          <div class="form-group"><label>Title *</label><input type="text" name="title" value="<%= c.title %>" required></div>
          <div class="form-row">
            <div class="form-group"><label>Category *</label><select name="category" required>
              <% ['plyometrics','sprinting','calisthenics','hockey'].forEach(cat => { %><option value="<%= cat %>" <%= c.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option><% }) %>
            </select></div>
            <div class="form-group"><label>Scoring *</label><select name="scoringType" required>
              <option value="max_reps" <%= c.scoring_type === 'max_reps' ? 'selected' : '' %>>Max Reps</option>
              <option value="min_time" <%= c.scoring_type === 'min_time' ? 'selected' : '' %>>Fastest Time</option>
            </select></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Unit *</label><input type="text" name="unit" value="<%= c.unit %>" required></div>
            <div class="form-group"><label>Date *</label><input type="date" name="challengeDate" value="<%= c.challenge_date %>" required></div>
          </div>
          <div class="form-group"><label>Team</label><select name="team_id"><option value="" <%= c.team_id ? '' : 'selected' %>>👥 All Teams (global)</option><% teams.forEach(t => { %><option value="<%= t.id %>" <%= c.team_id === t.id ? 'selected' : '' %>><%= t.name %></option><% }) %></select></div>
          <div class="form-group"><label>Description</label><textarea name="description" rows="4"><%= c.description %></textarea></div>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
      </details>
    </div>
  <% }) %>
</div>
<%- include('footer') %>
