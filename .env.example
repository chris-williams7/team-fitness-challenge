# Local development: point at your Turso DEV database (NOT production).
# Get these from: turso db show <dev-db> --url   and   turso db tokens create <dev-db>
TURSO_DATABASE_URL=libsql://your-dev-db-name.turso.io
TURSO_AUTH_TOKEN=your-dev-auth-token

# Signing secret for session cookies (any long random string is fine for dev)
SESSION_SECRET=dev-secret-change-me

# Team's local timezone (controls when the "today" challenge rolls over)
TIMEZONE=America/New_York
