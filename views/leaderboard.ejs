<%- include('header', { active: 'leaderboard' }) %>
<h1>🏆 Leaderboard</h1>
<div class="filter-tabs"><a href="/leaderboard?period=all" class="<%= period === 'all' ? 'active' : '' %>">All Time</a><a href="/leaderboard?period=month" class="<%= period === 'month' ? 'active' : '' %>">Last 30 Days</a><a href="/leaderboard?period=week" class="<%= period === 'week' ? 'active' : '' %>">Last 7 Days</a></div>
<% if (leaderboard.length === 0) { %><div class="card"><p class="muted">No scores recorded yet. Start competing! 💪</p></div><% } else { %>
  <table class="leaderboard-table"><thead><tr><th>Rank</th><th>Player</th><th>Total Points</th><th>Challenges Done</th><th>🥇</th><th>🥈</th><th>🥉</th></tr></thead><tbody>
    <% leaderboard.forEach(entry => { %>
      <tr class="<%= entry.rank <= 3 ? 'rank-' + entry.rank : '' %> <%= entry.username === user.username ? 'is-you' : '' %>"><td class="rank-cell"><% if (entry.rank === 1) { %>🥇<% } else if (entry.rank === 2) { %>🥈<% } else if (entry.rank === 3) { %>🥉<% } else { %>#<%= entry.rank %><% } %></td><td><strong><%= entry.username %></strong></td><td><span class="points-badge"><%= entry.totalPoints %> pts</span></td><td><%= entry.challengesDone %></td><td><%= entry.topFinishes['1st'] %></td><td><%= entry.topFinishes['2nd'] %></td><td><%= entry.topFinishes['3rd'] %></td></tr>
    <% }) %>
  </tbody></table>
  <h2>Completed Challenges</h2>
  <div class="challenge-list">
    <% challengesList.forEach(c => { %>
      <a href="/challenge/<%= c.id %>" class="challenge-item"><span class="badge badge-<%= c.category %>"><%= c.category.toUpperCase() %></span><div class="challenge-item-info"><strong><%= c.title %></strong><span class="muted"><%= c.challenge_date %></span></div><span class="arrow">→</span></a>
    <% }) %>
  </div>
<% } %>
<%- include('footer') %>