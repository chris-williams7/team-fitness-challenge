<%- include('header') %>
<h1>🔒 Change Password</h1>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
<div class="card"><form method="POST" action="/change-password"><div class="form-group"><label>Current Password</label><input type="password" name="currentPassword" required></div><div class="form-group"><label>New Password</label><input type="password" name="newPassword" required></div><div class="form-group"><label>Confirm New Password</label><input type="password" name="confirmPassword" required></div><button type="submit" class="btn btn-primary btn-full">Update</button></form></div>
<a href="/" class="back-link">← Back to Dashboard</a>
<%- include('footer') %>